#include "timer.h"

TIM_HandleTypeDef htim2;

// Contadores de tiempo por jugador
volatile uint32_t timer_jugador[NUM_JUGADORES] = {0};

// Jugador activo (el que está midiendo tiempo)
static volatile uint8_t jugador_activo = 0;

// ---------------------------------------------------------
// Cambiar jugador activo
// ---------------------------------------------------------
void TIMER_SetJugadorActivo(uint8_t jugador)
{
    if (jugador < NUM_JUGADORES)
        jugador_activo = jugador;
}

// ---------------------------------------------------------
// Inicializar TIM2 como temporizador básico
// ---------------------------------------------------------
void TIMER_Init(void)
{
    __HAL_RCC_TIM2_CLK_ENABLE();

    htim2.Instance = TIM2;

    // Según los apuntes:
    // UpdateEvent = (Prescaler+1)*(Period+1)
    // Queremos 1 ms → 1000 Hz
    // Si APB1 timer clock = 84 MHz:
    // Prescaler = 8399 → 84MHz/8400 = 10 kHz
    // Period = 9 → 10kHz/10 = 1 kHz → 1 ms

    htim2.Init.Prescaler     = 8399;
    htim2.Init.CounterMode   = TIM_COUNTERMODE_UP;
    htim2.Init.Period        = 9;
    htim2.Init.ClockDivision = TIM_CLOCKDIVISION_DIV1;

    HAL_TIM_Base_Init(&htim2);

    // NVIC
    HAL_NVIC_SetPriority(TIM2_IRQn, 0, 0);
    HAL_NVIC_EnableIRQ(TIM2_IRQn);
}

// ---------------------------------------------------------
// Arrancar temporizador con interrupciones
// ---------------------------------------------------------
void TIMER_Start(void)
{
    HAL_TIM_Base_Start_IT(&htim2);
}

// ---------------------------------------------------------
// Parar temporizador
// ---------------------------------------------------------
void TIMER_Stop(void)
{
    HAL_TIM_Base_Stop_IT(&htim2);
}

// ---------------------------------------------------------
// Callback de interrupción (llamado automáticamente)
// ---------------------------------------------------------
void HAL_TIM_PeriodElapsedCallback(TIM_HandleTypeDef *htim)
{
    if (htim->Instance == TIM2)
    {
        // Sumar 1 ms al jugador activo
        timer_jugador[jugador_activo]++;
    }
}

// ---------------------------------------------------------
// IRQ Handler
// ---------------------------------------------------------
void TIM2_IRQHandler(void)
{
    HAL_TIM_IRQHandler(&htim2);
}

